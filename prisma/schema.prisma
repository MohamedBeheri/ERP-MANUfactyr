// This is your Prisma schema file
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============
enum Role {
  ADMIN
  FACTORY
  WAREHOUSE
  SALES
  ACCOUNTANT
  DELEGATE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProductType {
  RAW // بن أخضر خام
  FINISHED // منتج نهائي
}

enum PaymentType {
  CASH // فوري
  CREDIT // آجل
}

enum CustomerType {
  RETAIL // قطاعي
  WHOLESALE // جملة
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  COMPLETED
  CANCELLED
  REFUNDED
}

enum OnlineOrderStatus {
  PENDING // طلب جديد
  CONFIRMED // اتأكد + اتخصم من المخزن
  PREPARING // بيتجهّز
  SHIPPED // خرج للتوصيل
  DELIVERED // اتسلّم
  CANCELLED // اتلغى
}

// ============== USERS & AUTH ==============
model User {
  id          String     @id @default(cuid())
  name        String
  username    String     @unique
  password    String // hashed with bcrypt
  role        Role       @default(SALES)
  permissions String[]   @default([]) // صلاحيات إضافية (أقسام النظام المسموح بها)
  status      UserStatus @default(ACTIVE)
  lastLogin   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  auditLogs      AuditLog[]
  purchases      Purchase[]
  productions    Production[]
  warehouseIns   WarehouseIn[]
  warehouseOuts  WarehouseOut[]
  invoices       Invoice[]
  deliveryOrders DeliveryOrder[]
  settlements    Settlement[]

  @@map("users")
}

// ============== CATEGORIES (التصنيفات) ==============
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  products Product[]

  @@map("categories")
}

// ============== PRODUCTION STAGES (مراحل التصنيع - قديم) ==============
model ProductionStage {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("production_stages")
}

// ============== STOCK STAGES (التصنيف المخزني — قابل للتخصيص) ==============
// أمثلة: بن أخضر (خام) / بن محمّص / بن مطحون / منتج نهائي معبّأ
model StockStage {
  id          String   @id @default(cuid())
  name        String   @unique
  sortOrder   Int      @default(0)
  sellable    Boolean  @default(false) // يظهر في المبيعات ونقطة البيع
  purchasable Boolean  @default(false) // يدخل بأمر شراء (خامات)
  warehouseId String? // المخزن الافتراضي للمرحلة دي
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  warehouse Warehouse?            @relation(fields: [warehouseId], references: [id])
  products  Product[]
  opInputs  ProductionOperation[] @relation("OpInputStage")
  opOutputs ProductionOperation[] @relation("OpOutputStage")

  @@map("stock_stages")
}

// ============== PRODUCTION OPERATIONS (عمليات التصنيع — قابلة للتخصيص) ==============
// كل عملية بتحدد: بتسحب من أنهي مرحلة مخزنية وبتنتج في أنهي مرحلة
// مثال: "تحميص" تسحب من (بن أخضر) وتنتج في (بن محمّص) — "طحن وتعبئة" تسحب من (بن محمّص) وتنتج في (منتج نهائي)
model ProductionOperation {
  id            String   @id @default(cuid())
  name          String   @unique
  inputStageId  String?
  outputStageId String?
  hasYieldLoss  Boolean  @default(true) // فيها هدر (زي التحميص)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  inputStage  StockStage?  @relation("OpInputStage", fields: [inputStageId], references: [id])
  outputStage StockStage?  @relation("OpOutputStage", fields: [outputStageId], references: [id])
  productions Production[]

  @@map("production_operations")
}

// ============== WAREHOUSES (المخازن) ==============
model Warehouse {
  id        String   @id @default(cuid())
  name      String   @unique
  location  String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  stocks ProductStock[]
  ins    WarehouseIn[]
  outs   WarehouseOut[]
  stages StockStage[]

  @@map("warehouses")
}

model ProductStock {
  id          String @id @default(cuid())
  warehouseId String
  productId   String
  quantity    Int    @default(0)

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@map("product_stocks")
}

// ============== PRODUCTS ==============
model Product {
  id             String      @id @default(cuid())
  name           String
  type           ProductType
  categoryId     String?
  stageId        String? // التصنيف المخزني (خام / محمّص / مطحون / نهائي)
  costPrice      Decimal     @db.Decimal(10, 2) // سعر التكلفة
  sellPrice      Decimal     @db.Decimal(10, 2) // سعر البيع قطاعي
  wholesalePrice Decimal     @default(0) @db.Decimal(10, 2) // سعر البيع جملة
  minStock       Int         @default(0) // الحد الأدنى
  quantity       Int         @default(0) // الكمية الإجمالية (كل المخازن)
  unit           String      @default("كجم") // وحدة القياس
  imageUrl       String? // صورة المنتج (رابط أو data URL)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  category         Category?         @relation(fields: [categoryId], references: [id])
  stockStage       StockStage?       @relation(fields: [stageId], references: [id])
  stocks           ProductStock[]
  purchaseItems    PurchaseItem[]
  productionItems  ProductionItem[]
  productionInputs ProductionInput[] @relation("ProductionInputProduct")
  recipeItems      RecipeItem[]      @relation("RecipeItemProduct")
  productionsAsRaw Production[]      @relation("ProductionRawProduct")
  invoiceItems     InvoiceItem[]
  deliveryItems    DeliveryItem[]
  warehouseIns     WarehouseIn[]
  warehouseOuts    WarehouseOut[]
  onlineOrderItems OnlineOrderItem[]

  @@map("products")
}

// ============== SUPPLIERS ==============
model Supplier {
  id             String   @id @default(cuid())
  name           String
  phone          String?
  address        String?
  email          String?
  totalPurchases Decimal  @default(0) @db.Decimal(12, 2)
  rating         Int      @default(5)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  // Relations
  purchases Purchase[]

  @@map("suppliers")
}

// ============== PURCHASES (شراء بن أخضر) ==============
model Purchase {
  id          String      @id @default(cuid())
  invoiceNo   String      @unique // رقم الفاتورة الورقية
  supplierId  String
  totalAmount Decimal     @db.Decimal(12, 2)
  notes       String?
  status      OrderStatus @default(COMPLETED)
  createdAt   DateTime    @default(now())
  createdById String

  // Relations
  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]
  creator  User           @relation(fields: [createdById], references: [id])

  @@map("purchases")
}

model PurchaseItem {
  id         String  @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  // Relations
  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

// ============== PRODUCTION (التصنيع) ==============
model Production {
  id           String      @id @default(cuid())
  orderNo      String      @unique
  lineType     String      @default("ROASTING") // ROASTING (خط التحميص من البن الأخضر) / PROCESSING (خط الخلط والطحن والتعبئة)
  stage        String      @default("تحميص") // اسم المرحلة
  batchNo      String? // رقم التشغيلة/اللوط (Lot/Batch)
  roastLevel   String? // درجة التحميص: فاتح / وسط / غامق
  grindType    String? // درجة الطحن: ناعم جداً / ناعم / متوسط / خشن
  inputWeight  Int         @default(0) // إجمالي وزن المدخلات (جرام)
  outputWeight Int         @default(0) // إجمالي وزن المخرجات (جرام)
  wasteWeight  Int         @default(0) // الهدر (جرام)
  wastePercent Decimal     @default(0) @db.Decimal(5, 2) // نسبة الهدر %
  expiryDate   DateTime? // تاريخ انتهاء الصلاحية للمنتج الناتج
  recipeId     String? // الوصفة المستخدمة (BOM)
  operationId  String? // عملية التصنيع المستخدمة
  // حقول قديمة للتوافق مع البيانات السابقة
  rawProductId String?
  rawUsed      Int         @default(0)
  opCost       Decimal     @default(0) @db.Decimal(10, 2) // تكلفة التشغيل
  notes        String?
  status       OrderStatus @default(COMPLETED)
  createdAt    DateTime    @default(now())
  createdById  String

  // Relations
  rawProduct Product?             @relation("ProductionRawProduct", fields: [rawProductId], references: [id])
  recipe     Recipe?              @relation(fields: [recipeId], references: [id])
  operation  ProductionOperation? @relation(fields: [operationId], references: [id])
  inputs     ProductionInput[]
  items      ProductionItem[]
  creator    User                 @relation(fields: [createdById], references: [id])

  @@map("productions")
}

// مدخلات أمر التصنيع (خامات متعددة — للخلطات BOM)
model ProductionInput {
  id           String  @id @default(cuid())
  productionId String
  productId    String
  quantity     Int // الكمية المستخدمة (جرام)
  percentage   Decimal @default(0) @db.Decimal(5, 2) // النسبة في الخلطة %

  production Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  product    Product    @relation("ProductionInputProduct", fields: [productId], references: [id])

  @@map("production_inputs")
}

model ProductionItem {
  id           String @id @default(cuid())
  productionId String
  productId    String
  quantity     Int // الكمية المنتجة

  // Relations
  production Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@map("production_items")
}

// ============== RECIPES / BOM (الوصفات وقوائم المواد) ==============
model Recipe {
  id            String   @id @default(cuid())
  name          String   @unique
  lineType      String   @default("PROCESSING") // الخط اللي بتنتمي له الوصفة
  outputName    String? // اسم المنتج النهائي المتوقع
  roastLevel    String?
  grindType     String?
  expectedWaste Decimal  @default(0) @db.Decimal(5, 2) // نسبة الهدر المتوقعة %
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  items       RecipeItem[]
  productions Production[]

  @@map("recipes")
}

model RecipeItem {
  id         String  @id @default(cuid())
  recipeId   String
  productId  String
  percentage Decimal @db.Decimal(5, 2) // نسبة الخامة في الوصفة %

  recipe  Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  product Product @relation("RecipeItemProduct", fields: [productId], references: [id])

  @@map("recipe_items")
}

// ============== WAREHOUSE (المخزن) ==============
model WarehouseIn {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String?
  quantity    Int
  source      String // المصدر (مثال: "المصنع - أمر تصنيع #1")
  notes       String?
  createdAt   DateTime @default(now())
  createdById String

  // Relations
  product   Product    @relation(fields: [productId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  creator   User       @relation(fields: [createdById], references: [id])

  @@map("warehouse_ins")
}

model WarehouseOut {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String?
  quantity    Int
  target      String // الجهة (مثال: "مندوب: أحمد" أو "فرع رئيسي")
  reason      String // السبب (فاتورة بيع، أمر تسليم، مرتجعات)
  notes       String?
  createdAt   DateTime @default(now())
  createdById String

  // Relations
  product   Product    @relation(fields: [productId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  creator   User       @relation(fields: [createdById], references: [id])

  @@map("warehouse_outs")
}

// ============== CUSTOMERS (العملاء) ==============
model Customer {
  id             String       @id @default(cuid())
  name           String
  phone          String?
  address        String?
  type           PaymentType  @default(CASH)
  customerType   CustomerType @default(RETAIL) // جملة أو قطاعي
  creditLimit    Decimal      @default(0) @db.Decimal(12, 2) // الحد الائتماني
  balance        Decimal      @default(0) @db.Decimal(12, 2) // الرصيد المدين
  totalPurchases Decimal      @default(0) @db.Decimal(12, 2)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  // Relations
  invoices     Invoice[]
  onlineOrders OnlineOrder[]

  @@map("customers")
}

// ============== SALES POINTS (نقاط البيع) ==============
model SalesPoint {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  manager   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relations
  invoices Invoice[]

  @@map("sales_points")
}

// ============== INVOICES (فواتير البيع) ==============
model Invoice {
  id              String        @id @default(cuid())
  invoiceNo       String        @unique
  customerId      String
  totalAmount     Decimal       @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(5, 2) // نسبة الخصم
  netAmount       Decimal       @db.Decimal(12, 2)
  type            PaymentType
  paymentMethod   String        @default("نقدي") // نقدي / فيزا / انستاباي / مختلط
  pointId         String?
  delegateId      String? // لو الفاتورة اتعملت أثناء جولة توزيع مندوب
  deliveryOrderId String? // الجولة المرتبطة
  status          InvoiceStatus @default(COMPLETED)
  createdAt       DateTime      @default(now())
  createdById     String

  // Relations
  customer      Customer       @relation(fields: [customerId], references: [id])
  point         SalesPoint?    @relation(fields: [pointId], references: [id])
  delegate      Delegate?      @relation(fields: [delegateId], references: [id])
  deliveryOrder DeliveryOrder? @relation(fields: [deliveryOrderId], references: [id])
  items         InvoiceItem[]
  creator       User           @relation(fields: [createdById], references: [id])

  @@map("invoices")
}

model InvoiceItem {
  id         String  @id @default(cuid())
  invoiceId  String
  productId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  // Relations
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

// ============== DELEGATES (المندوبين) ==============
model Delegate {
  id             String   @id @default(cuid())
  name           String
  phone          String?
  carNumber      String? // رقم العربية
  area           String? // المنطقة
  route          String? // خط السير
  commissionRate Decimal  @default(5) @db.Decimal(5, 2) // نسبة العمولة
  totalSales     Decimal  @default(0) @db.Decimal(12, 2)
  commissionDue  Decimal  @default(0) @db.Decimal(12, 2)
  commissionPaid Decimal  @default(0) @db.Decimal(12, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  // Relations
  deliveryOrders DeliveryOrder[]
  settlements    Settlement[]
  invoices       Invoice[]

  @@map("delegates")
}

// ============== DELIVERY ORDERS (أوامر التسليم) ==============
model DeliveryOrder {
  id          String      @id @default(cuid())
  orderNo     String      @unique
  delegateId  String
  status      OrderStatus @default(PENDING)
  notes       String?
  createdAt   DateTime    @default(now())
  createdById String

  // Relations
  delegate   Delegate       @relation(fields: [delegateId], references: [id])
  items      DeliveryItem[]
  invoices   Invoice[]
  settlement Settlement?
  creator    User           @relation(fields: [createdById], references: [id])

  @@map("delivery_orders")
}

model DeliveryItem {
  id              String @id @default(cuid())
  deliveryOrderId String
  productId       String
  quantity        Int

  // Relations
  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("delivery_items")
}

// ============== SETTLEMENTS (تسويات المندوبين) ==============
model Settlement {
  id              String   @id @default(cuid())
  delegateId      String
  deliveryOrderId String?  @unique // الجولة اللي التسوية دي بتاعتها
  soldQty         Int      @default(0) // المباع
  returnedQty     Int      @default(0) // المرتجع
  cashAmount      Decimal  @default(0) @db.Decimal(12, 2) // النقدية
  creditAmount    Decimal  @default(0) @db.Decimal(12, 2) // الآجل
  commission      Decimal  @default(0) @db.Decimal(12, 2) // العمولة
  notes           String?
  createdAt       DateTime @default(now())
  createdById     String

  // Relations
  delegate      Delegate       @relation(fields: [delegateId], references: [id])
  deliveryOrder DeliveryOrder? @relation(fields: [deliveryOrderId], references: [id])
  creator       User           @relation(fields: [createdById], references: [id])

  @@map("settlements")
}

// ============== CASH FLOW (التدفق النقدي) ==============
model CashFlow {
  id          String   @id @default(cuid())
  description String
  type        String // "IN" or "OUT"
  amount      Decimal  @db.Decimal(12, 2)
  balance     Decimal  @db.Decimal(12, 2)
  reference   String? // رقم الفاتورة/الأمر
  createdAt   DateTime @default(now())

  @@map("cash_flow")
}

// ============== AUDIT LOG (سجل المراجعة) ==============
model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String // نوع العملية
  description String // الوصف
  impact      String // التأثير
  ipAddress   String?
  createdAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ============== ONLINE STORE (متجر العميل أونلاين) ==============
model StoreSettings {
  id             String   @id @default("store")
  storeName      String   @default("شركة البدر لتجارة البن")
  tagline        String   @default("قهوة طازجة تتحمّص وتُطحن حسب طلبك")
  heroImage      String?
  phone          String?
  whatsapp       String?
  address        String?
  deliveryFee    Decimal  @default(0) @db.Decimal(10, 2)
  minOrder       Decimal  @default(0) @db.Decimal(10, 2)
  warehouseId    String? // المخزن اللي بيتباع منه أونلاين
  isOpen         Boolean  @default(true) // المتجر شغّال ولا لأ
  showOutOfStock Boolean  @default(true)
  codEnabled     Boolean  @default(true) // الدفع عند الاستلام
  updatedAt      DateTime @updatedAt

  @@map("store_settings")
}

model OnlineOrder {
  id            String            @id @default(cuid())
  orderNo       String            @unique
  customerId    String?
  customerName  String
  phone         String
  address       String
  notes         String?
  subtotal      Decimal           @db.Decimal(12, 2)
  deliveryFee   Decimal           @default(0) @db.Decimal(10, 2)
  total         Decimal           @db.Decimal(12, 2)
  paymentMethod String            @default("الدفع عند الاستلام")
  status        OnlineOrderStatus @default(PENDING)
  warehouseId   String?
  invoiceId     String?
  createdAt     DateTime          @default(now())

  customer Customer?         @relation(fields: [customerId], references: [id])
  items    OnlineOrderItem[]

  @@map("online_orders")
}

model OnlineOrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)

  order   OnlineOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product     @relation(fields: [productId], references: [id])

  @@map("online_order_items")
}

model HeroSlide {
  id        String   @id @default(cuid())
  type      String   @default("IMAGE") // IMAGE | VIDEO
  media     String // رابط أو data URL
  badge     String?
  title1    String?
  title2    String?
  subtitle  String?
  ctaText   String?
  ctaLink   String?  @default("/store")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("hero_slides")
}
